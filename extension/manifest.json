{
  "manifest_version": 3,
  "name": "Word Catcher Pro",
  "version": "1.0",
  "description": "לוכד מילים, מעשיר ושומר למסלול הלמידה",
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:3000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ]
}